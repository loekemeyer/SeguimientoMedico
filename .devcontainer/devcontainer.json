{
  "name": "SeguimientoMedico — Health Monitor",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  // Al crear el Codespace: instala dependencias, corre los tests y la demo,
  // así apenas se abre ya ves que todo funciona (sin escribir nada).
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt",
  "postAttachCommand": "bash .devcontainer/welcome.sh",

  // El puerto de la API (uvicorn) queda accesible desde el navegador del celular.
  "forwardPorts": [8001],
  "portsAttributes": {
    "8001": { "label": "Health Monitor API", "onAutoForward": "notify" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"]
      }
    }
  }
}
