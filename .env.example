# ============================================================
#  Variables de entorno — copiar a .env y completar
# ============================================================

# --- Seguridad / cifrado (Ley 25.326) ---
# Clave AES-256 en base64 (32 bytes). Generar con:
#   python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# --- Base de datos ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/seguimiento

# --- Twilio (WhatsApp Business / Media Streams) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PUBLIC_BASE_URL=https://example.ngrok.io   # URL pública para webhooks/WS

# --- Cerebro de IA (elegir proveedor) ---
REALTIME_PROVIDER=openai                   # openai | gemini
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
GEMINI_API_KEY=
GEMINI_REALTIME_MODEL=gemini-2.0-flash-live

# --- Triaje / alertas ---
EMERGENCY_WEBHOOK=                          # central de emergencias / médico de guardia

# --- Operación ---
LOG_LEVEL=INFO
