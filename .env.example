# ============================================================
#  Variables de entorno — copiar a .env y completar
# ============================================================
# Nota: no pongas comentarios en la MISMA línea que un valor; van arriba.

# --- Seguridad / cifrado (Ley 25.326) ---
# Clave AES-256 en base64 (32 bytes). Generar con:
#   python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# Secreto para firmar los tokens de sesión (login). Generar con:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=

# --- Base de datos ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/seguimiento

# --- Twilio (WhatsApp Business / Media Streams) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Número de voz de Twilio (el del trial) para hacer llamadas, ej. +1...
TWILIO_VOICE_FROM=
# Plantilla aprobada (HX...) para alertas proactivas
TWILIO_CONTENT_SID=
# URL pública para webhooks/WS (ej. ngrok)
PUBLIC_BASE_URL=

# --- Cerebro de IA (proveedor: openai | gemini) ---
REALTIME_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-mini
GEMINI_API_KEY=
GEMINI_REALTIME_MODEL=gemini-2.0-flash-live

# --- Triaje / alertas ---
# URL de la central de emergencias / médico de guardia (dejar vacío si no aplica)
EMERGENCY_WEBHOOK=

# --- Operación ---
LOG_LEVEL=INFO
